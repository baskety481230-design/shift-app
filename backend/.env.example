APP_ENV=development
DATABASE_URL=sqlite:///./shift.db
SECRET_KEY=change-me-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# CORS / frontend
FRONTEND_URL=http://localhost:5173

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:you@example.com

# Bootstrap manager (first Google login with this email becomes manager)
INITIAL_MANAGER_EMAIL=

# Timezone
TZ=Asia/Tokyo

# Cookie settings (set SECURE=true in production / HTTPS)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
